{
  "name": "ai-broadcast-extension",
  "version": "2.11.0",
  "license": "AGPL-3.0-or-later",
  "private": true,
  "scripts": {
    "prepare": "npm run hooks:install",
    "build": "npm run build:extension",
    "build:extension": "npm run build:extension --prefix app && npm run build:content",
    "build:content": "node scripts/build-content.mjs",
    "build:site": "npm run build:site --prefix app",
    "build:design-system": "npm run build:design-system --prefix app",
    "build:all": "npm run build:extension && npm run build:site && npm run build:design-system",
    "package:extension": "node scripts/package-extension.mjs",
    "package:extension:min": "node scripts/package-extension.mjs --minify-runtime",
    "capture:screenshot": "node scripts/capture-popup-screenshot.mjs",
    "build:icons": "node scripts/build-icons.mjs",
    "hooks:install": "git config --local core.hooksPath .githooks",
    "release:stage": "npm run build:extension && npm run package:extension && git add -A app/dist-extension && git status --short -- app/dist-extension",
    "test:input": "node scripts/test-input-support.mjs",
    "test:popup": "node scripts/test-popup-ui.mjs",
    "auth:export": "node scripts/export-auth-state.mjs",
    "validate:selectors": "node scripts/validate-selectors.mjs",
    "diagnose": "node scripts/diagnose.mjs",
    "init:selectors-repo": "bash scripts/init-selectors-repo.sh"
  },
  "devDependencies": {
    "playwright": "^1.49.0",
    "sharp": "^0.33.5"
  }
}
