# Sendol Extension 环境变量配置

# Supabase 配置（用于候补名单功能）
# 如果不配置，将使用 localStorage 作为降级方案
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Resend API Key（用于发送邮件）
# 获取地址：https://resend.com/api-keys
# 注意：此 Key 需要在 Supabase Edge Function 中配置，不是前端使用
VITE_RESEND_API_KEY=your-resend-api-key

# 部署 Edge Function 时需要设置的环境变量：
# - SUPABASE_URL
# - SUPABASE_SERVICE_ROLE_KEY
# - RESEND_API_KEY
