{
  "mode": "override",
  "findInput": [
    "textarea[placeholder]",
    "div[contenteditable=\"true\"]",
    "textarea"
  ],
  "findSendBtn": [
    "button[type=\"submit\"]:not([disabled])",
    "button[class*=\"send\"]:not([disabled])",
    "button[aria-label*=\"发送\"]",
    "button[aria-label*=\"Send\"]",
    "button[data-testid*=\"send\"]",
    "form button[type=\"submit\"]"
  ]
}
